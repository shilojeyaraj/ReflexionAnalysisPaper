OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o
CHROMA_PERSIST_DIR=./chroma_store
SQLITE_DB_PATH=./reflexion_episodes.db
RESULTS_DIR=./results

# BFCL (Berkeley Function Calling Leaderboard) — tool-use domain
# No API key required. Data is bundled with bfcl-eval package.
# Set BFCL_CATEGORY to control which task category is used (default: simple_python)
BFCL_CATEGORY=simple_python
