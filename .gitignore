# Secrets — never commit
.env

# pip editable install artifacts (e.g. human-eval cloned by pip install -e git+...)
src/

# Python cache / build
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ChromaDB stores (all chroma_* directories are generated by experiments)
chroma_*/

# SQLite databases (generated by experiments; not needed in source control)
*.db

# Experiment logs (verbose, regenerable)
results/*.log
results/reports/
results/k_ablation/

# pytest
.pytest_cache/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Generated figures (regenerable from analysis scripts)
figures/

# Claude Code session data
.claude/
